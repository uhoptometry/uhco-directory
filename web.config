<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <security>
            <requestFiltering>
                <!-- Allow larger ZIP uploads for admin bulk media transfer (bytes). -->
                <requestLimits maxAllowedContentLength="209715200" />
            </requestFiltering>
        </security>
        <!-- Remove WebDAV and the built-in OPTIONS handler so that HTTP OPTIONS
             preflight requests (CORS) are passed through to ColdFusion rather
             than being intercepted by IIS and returning 403.14. -->
        <modules>
            <remove name="WebDAVModule" />
        </modules>
        <handlers>
            <remove name="WebDAV" />
            <remove name="OPTIONSVerbHandler" />
        </handlers>
        <httpErrors errorMode="Detailed" />
        <staticContent>
            <remove fileExtension=".webp" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
        </staticContent>
        <rewrite>
            <rules>
                
                <rule name="Block Model Direct Access" stopProcessing="true">
                    <match url="^model/.*" />
                    <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access denied" />
                </rule>
                <rule name="API v1 Dispatcher" stopProcessing="true">
                    <match url="^api/v1(/.*)?$" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{R:1}" pattern="\." negate="true" />
                        <add input="{QUERY_STRING}" pattern="_path=" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="api/v1/index.cfm?_path={R:1}" appendQueryString="true" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
